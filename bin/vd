#!/bin/sh

. _LIBRARY_PATH_/_APPLICATION_NAME_/include.sh

_OPTIONS="--no-color -q"

_lock

for f in $(find _APPLICATION_DATA_PATH_/queued -type f)
do
  _video_meta
  _OUTPUT=_APPLICATION_DATA_PATH_/downloaded/${_KEY}.mp4

  if [ ! -e $_OUTPUT ]
  then
    echo "downloading $(_video_info)"

    youtube-dl $_OPTIONS "$_URL" -o $_OUTPUT
  fi
done

_cleanup
